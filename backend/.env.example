# Get your keys at https://console.groq.com
# Multiple keys (comma-separated) rotate round-robin: more throughput,
# automatic failover on rate limits (429) and dead keys (401).
GROQ_API_KEYS=gsk_key_one,gsk_key_two,gsk_key_three
# Single-key fallback (used if GROQ_API_KEYS is empty):
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
ROW_LIMIT=500
